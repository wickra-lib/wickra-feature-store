# The wickra-feature-store C ABI header and library are provided out-of-tree via
# the WKFEATURESTORE_INC (include dir) and WKFEATURESTORE_LIB (library dir)
# environment variables, set by CI / the installer. The Makevars do not bake an
# rpath; the loader must find the shared library via LD_LIBRARY_PATH /
# DYLD_LIBRARY_PATH at run time.
PKG_CPPFLAGS = -I$(WKFEATURESTORE_INC)
PKG_LIBS = -L$(WKFEATURESTORE_LIB) -lwickra_feature_store
